{
  "$schema": "https://json.schemastore.org/package",
  "name": "@msom/types-vue2",
  "version": "1.0.0",
  "description": "Vue 2 插件类型定义",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "check": "tsc --noEmit",
    "build": "pnpm run clean && pnpm run check && vite build --config ../../vite.config.ts",
    "release": "pnpm run build && pnpm publish"
  },
  "keywords": [
    "vue",
    "vue2",
    "plugin"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "peerDependencies": {
    "vue": "^2.x"
  },
  "devDependencies": {
    "@types/vue": "^2.0.0",
    "element-ui": "2.15.13",
    "vite": "^5.4.21",
    "vue": "^2.7.16"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
